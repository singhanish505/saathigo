# SaathiGo Backend - Environment variables
NODE_ENV=development
PORT=4000

# JWT
JWT_SECRET=replace-me-in-prod-with-32-char-random
JWT_EXPIRES_IN=7d

# Redis (location streaming + rate limit + cache)
REDIS_URL=redis://localhost:6379
REDIS_GEO_PREFIX=drivers:geo

# Postgres (transactional)
DATABASE_URL=postgres://saathigo:saathigo@localhost:5432/saathigo

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Sakhi Shield
ROUTE_DEVIATION_METERS=250
LOCATION_GAP_SECONDS=90

# Pricing
SURGE_CAP_METRO=2.2
SURGE_CAP_TIER2=1.6

# Mock-mode (dev only) - skips real Redis/Postgres
MOCK_MODE=true
